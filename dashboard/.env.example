# ============================================
# ESP32C3 WEATHER STATION BACKEND CONFIGURATION
# ============================================
# Rename this file to .env and fill in the values

# MongoDB Atlas Connection String
# Get it from MongoDB Atlas: Database -> Connect -> Connect your application
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/database_name?retryWrites=true&w=majority"

# Database name
DB_NAME="weather_station"

# Collection name
COLLECTION_NAME="readings"

# API Key for authentication (use a secure, randomly generated key)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY="your_secure_api_key_here"

# Port (automatically injected on Render/Railway, local uses 4000)
PORT=4000

# Auto-refresh interval in seconds (REQUIRED - no default value)
REFRESH_INTERVAL_SECONDS=30